---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import BoardCard from "../components/BoardCard.astro";

const boardMembers = [
    {
        initials: "SR",
        name: "Saisharan Raja",
        role: "President",
        description:
            "Leading innovation and strategic direction for LNU AI Society.",
        email: "saisharan@lnuais.com",
        linkedin: "https://www.linkedin.com/in/saisharanraja/",
    },
    {
        initials: "LP",
        name: "Laknath Ranaraja Perera",
        role: "Vice President",
        description:
            "Focused on operations, planning, and society coordination.",
        email: "laknath@lnuais.com",
        linkedin: "https://www.linkedin.com/in/lranaraja/",
    },
    {
        initials: "AS",
        name: "Abdirashiid Sammantar",
        role: "Head of Communications",
        description:
            "Responsible for outreach, messaging, and media relations.",
        email: "abdirashiid@lnuais.com",
        linkedin:
            "https://www.linkedin.com/in/abdirashiid-sammantar-3b7863238/",
    },
    {
        initials: "YM",
        name: "Younus Mashoor",
        role: "Head of Marketing",
        description:
            "Leading marketing initiatives and promotional strategies.",
        email: "younus@lnuais.com",
        linkedin: "https://www.linkedin.com/in/younusmashoor/",
    },
    {
        initials: "WM",
        name: "William McCallum-Vallmark",
        role: "Secretary",
        description: "Organizing meetings, records, and official documents.",
        email: "william@lnuais.com",
        linkedin:
            "https://www.linkedin.com/in/william-mc-callum-vallmark-4118a01ba/",
    },
    {
        initials: "KC",
        name: "Kemal Cikota",
        role: "Head of Business Relations",
        description:
            "Managing partnerships and external business relationships.",
        email: "kemal@lnuais.com",
        linkedin: "https://www.linkedin.com/in/kemal-cikota-19b509252/",
    },
    {
        initials: "AG",
        name: "Armin Coco Grbovic",
        role: "Treasurer",
        description: "Managing finances, budgets, and financial planning.",
        email: "armin@lnuais.com",
        linkedin: "https://www.linkedin.com/in/armin-coco-grbovic-195a72237/",
    },
];

const committeeMembers = [
    {
        initials: "KA",
        name: "Keenan Arsianto",
        role: "Art Director",
        description:
            "Creating visual identity and designing graphics for society initiatives.",
        email: "keenan@lnuais.com",
        linkedin: "https://www.linkedin.com/in/keenan-arsianto-63b00334b/",
    },
    {
        initials: "EK",
        name: "Ebbe Karlstad",
        role: "Web Developer",
        description:
            "Building and maintaining the society's digital platforms and web presence.",
        email: "ebbe@lnuais.com",
        linkedin: "https://www.linkedin.com/in/ebbekarlstad/",
    },
];
---

<!doctype html>
<html lang="en" class="h-full">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/x-icon" href="/images/logo.png" />
        <title>About - LNU AI Society</title>
    </head>

    <body
        class="flex min-h-screen flex-col bg-[#232326] font-sans text-[#fcfbf8]"
    >
        <Nav />

        <div class="container mx-auto flex-1 px-6 pb-32 pt-28 md:px-10">
            <div class="about-hero text-center">
                <h1 class="text-4xl font-bold text-[#fcfbf8] md:text-5xl">
                    Board Members at LNU AI Society
                </h1>
                <p
                    class="mx-auto mt-4 max-w-[75ch] text-base font-medium text-[#b0b0b0] md:text-lg"
                >
                    Our dedicated team of students leading the AI revolution at
                    Linnaeus University.
                </p>
            </div>

            <div
                class="board-grid mx-auto mt-10 grid max-w-[83rem] gap-8 md:grid-cols-2 xl:grid-cols-3"
            >
                {boardMembers.map((member) => <BoardCard {...member} />)}
            </div>

            <div
                class="divider mx-auto my-20 h-px max-w-[83rem] bg-gradient-to-r from-transparent via-[#ffe000]/30 to-transparent"
            >
            </div>

            <div class="committee-hero text-center">
                <h1 class="text-4xl font-bold text-[#fcfbf8] md:text-5xl">
                    Committee Members
                </h1>
                <p
                    class="mx-auto mt-4 max-w-[75ch] text-base font-medium text-[#b0b0b0] md:text-lg"
                >
                    Supporting our mission with specialized skills and
                    expertise.
                </p>
            </div>

            <div
                class="committee-grid mx-auto mt-10 grid max-w-[83rem] gap-8 md:grid-cols-2"
            >
                {committeeMembers.map((member) => <BoardCard {...member} />)}
            </div>

            <div
                class="divider mx-auto my-20 h-px max-w-[83rem] bg-gradient-to-r from-transparent via-[#ffe000]/30 to-transparent"
            >
            </div>

            <div
                class="contact-section-compact mx-auto max-w-[83rem] text-center"
            >
                <h2 class="text-3xl font-bold text-[#fcfbf8] md:text-4xl">
                    Get in Touch
                </h2>
                <p
                    class="contact-intro mx-auto mt-3 max-w-[75ch] text-base text-[#b0b0b0] md:text-lg"
                >
                    Have questions or want to get involved? We'd love to hear
                    from you!
                </p>

                <div
                    class="contact-buttons mt-8 flex flex-wrap justify-center gap-6"
                >
                    <a
                        href="mailto:contact@lnuais.com"
                        class="contact-btn group inline-flex min-h-[44px] items-center gap-3 rounded-xl border border-[#404040] bg-[#2a2a2e] px-6 py-4 text-base font-medium text-[#fcfbf8] transition hover:border-[#ffe000] hover:bg-[#ffe000] hover:text-[#232326]"
                    >
                        <img
                            src="images/mail.svg"
                            alt=""
                            class="contact-btn-icon h-5 w-5 brightness-0 invert transition group-hover:invert-0"
                        />
                        Email Us
                    </a>
                    <a
                        href="https://maps.google.com/?q=Linnaeus+University+Växjö"
                        target="_blank"
                        class="contact-btn group inline-flex min-h-[44px] items-center gap-3 rounded-xl border border-[#404040] bg-[#2a2a2e] px-6 py-4 text-base font-medium text-[#fcfbf8] transition hover:border-[#ffe000] hover:bg-[#ffe000] hover:text-[#232326]"
                    >
                        <img
                            src="images/map-pin.svg"
                            alt=""
                            class="contact-btn-icon h-5 w-5 brightness-0 invert transition group-hover:invert-0"
                        />
                        Visit Campus
                    </a>
                </div>

                <div
                    class="office-hours mx-auto mt-8 inline-flex max-w-fit items-center gap-4 rounded-xl border border-[#404040] bg-[#2a2a2e] px-8 py-6"
                >
                    <img
                        src="images/clock.svg"
                        alt=""
                        class="office-hours-icon h-8 w-8 brightness-0 invert"
                    />
                    <div class="office-hours-text text-left">
                        <h3
                            class="text-sm font-semibold uppercase tracking-wide text-[#ffe000]"
                        >
                            Office Hours
                        </h3>
                        <p class="mt-2 text-sm text-[#b0b0b0]">
                            Tuesdays: 14:00 - 16:00 • Thursdays: 10:00 - 12:00 •
                            Or by appointment
                        </p>
                    </div>
                </div>
            </div>
            <div
                class="divider mx-auto my-20 h-px max-w-[83rem] bg-gradient-to-r from-transparent via-[#ffe000]/30 to-transparent"
            >
            </div>

            <div class="documents-cta mx-auto max-w-[83rem] text-center">
                <h2 class="text-3xl font-semibold text-[#fcfbf8]">
                    Official Documents
                </h2>
                <p
                    class="mx-auto mt-2 max-w-[70ch] text-sm text-[#9aa0a6] md:text-base"
                >
                    View official bylaws and professional documents, including
                    policies, agreements, and other governance materials for LNU
                    AI Society.
                </p>
                <a
                    href="documents.html"
                    class="cta-button mt-4 inline-block rounded-xl border border-[#404040] bg-[#2a2a2e] px-6 py-3 text-sm font-medium text-[#fcfbf8] transition hover:border-[#ffe000] hover:bg-[#ffe000] hover:text-[#232326]"
                    >View Documents</a
                >
            </div>
        </div>

        <Footer />
        <script is:inline src="scripts/navbar.js"></script>
        <script is:inline src="scripts/hamburger.js"></script>
    </body>
</html>

---
import '../styles/global.css';
import DashboardNav from '../components/DashboardNav.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/images/logo.png" />
    <script is:inline src="scripts/config.js"></script>

    <title>Dashboard - LNU AI Society</title>
  </head>

  <body class="flex min-h-screen flex-col bg-[#0f0f11] bg-[radial-gradient(circle_at_50%_0%,#1a1a20_0%,#0f0f11_75%)] font-sans text-[#fcfbf8]">
    <DashboardNav />

    <div class="container mx-auto flex-1 max-w-[1000px] px-6 pb-20 pt-28">
      <div id="loading" class="mt-24 text-center">
        <h2 class="text-2xl font-semibold text-[#fcfbf8]">Loading Profile...</h2>
      </div>

      <div id="dashboardContent" class="space-y-10" style="display: none">
        <div class="hero text-center">
          <h1 class="text-4xl font-bold text-transparent bg-gradient-to-br from-white to-[#a0a0a0] bg-clip-text">
            Student Dashboard
          </h1>
          <p class="mt-2 text-base text-[#888]">
            Manage your membership and profile details.
          </p>
        </div>

        <div class="card rounded-2xl border border-[#27272a] bg-[#18181b] p-10 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.1),0_2px_4px_-1px_rgba(0,0,0,0.06)]">
          <div id="notification" class="alert-box" style="display: none"></div>

          <!-- Profile removed from card (now shown in navbar) -->

          <div id="viewMode" class="info-grid grid gap-5 md:grid-cols-2">
            <div class="info-item rounded-xl border border-[#27272a] bg-[#202024] p-5 transition hover:-translate-y-0.5 hover:border-[#3f3f46]">
              <label class="text-xs font-bold uppercase tracking-widest text-[#ffe000]">Programme</label>
              <div class="info-value mt-2 text-lg font-medium text-white" id="displayProgram">N/A</div>
            </div>
            <div class="info-item rounded-xl border border-[#27272a] bg-[#202024] p-5 transition hover:-translate-y-0.5 hover:border-[#3f3f46]">
              <label class="text-xs font-bold uppercase tracking-widest text-[#ffe000]">Experience Level</label>
              <div class="info-value mt-2 text-lg font-medium text-white" id="displayLevel">N/A</div>
            </div>
          </div>

          <div id="editMode" class="info-grid hidden grid gap-5 md:grid-cols-2">
            <div class="info-item rounded-xl border border-[#27272a] bg-[#202024] p-5">
              <label class="text-xs font-bold uppercase tracking-widest text-[#ffe000]" for="editProgram">Programme</label>
              <input
                type="text"
                id="editProgram"
                class="edit-input mt-3 w-full rounded-lg border border-[#3f3f46] bg-[#0f0f11] px-4 py-3 text-sm text-white transition focus:border-[#ffe000] focus:outline-none focus:ring-2 focus:ring-[#ffe000]/20"
                placeholder="e.g. Computer Science"
              />
            </div>
            <div class="info-item rounded-xl border border-[#27272a] bg-[#202024] p-5">
              <label class="text-xs font-bold uppercase tracking-widest text-[#ffe000]" for="editLevel">Experience Level</label>
              <select
                id="editLevel"
                class="edit-input mt-3 w-full appearance-none rounded-lg border border-[#3f3f46] bg-[#0f0f11] px-4 py-3 text-sm text-white transition focus:border-[#ffe000] focus:outline-none focus:ring-2 focus:ring-[#ffe000]/20"
              >
                <option value="LOW">Beginner</option>
                <option value="MID">Intermediate</option>
                <option value="HIGH">Advanced</option>
              </select>
            </div>
          </div>

          <div class="action-buttons mt-8 flex flex-wrap items-center gap-3 border-t border-[#27272a] pt-6">
            <button
              id="editBtn"
              class="primary rounded-lg bg-[#ffe000] px-6 py-3 text-xs font-semibold uppercase tracking-wider text-black transition hover:-translate-y-0.5 hover:bg-[#ffea2e] hover:shadow-[0_4px_12px_rgba(255,224,0,0.2)]"
              onclick="toggleEditMode()"
            >
              Edit Profile
            </button>
            <button
              id="saveBtn"
              class="primary hidden rounded-lg bg-[#ffe000] px-6 py-3 text-xs font-semibold uppercase tracking-wider text-black transition hover:-translate-y-0.5 hover:bg-[#ffea2e] hover:shadow-[0_4px_12px_rgba(255,224,0,0.2)]"
              onclick="saveProfile()"
            >
              Save Changes
            </button>
            <button
              id="cancelBtn"
              class="secondary hidden rounded-lg border border-[#3f3f46] px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#a1a1aa] transition hover:border-[#71717a] hover:bg-white/5 hover:text-white"
              onclick="toggleEditMode()"
            >
              Cancel
            </button>

            <button
              onclick="handleLogout()"
              class="secondary ml-auto rounded-lg border border-[#fc8181] px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#fc8181] transition hover:bg-[#fc8181]/10"
            >
              Log Out
            </button>
          </div>

          <div class="delete-section mt-6 flex justify-end">
            <button
              onclick="showDeleteModal()"
              class="delete-btn rounded-md border border-[#7f1d1d] px-4 py-2 text-xs font-semibold uppercase tracking-wider text-[#ef4444] transition hover:bg-[#ef4444]/10"
            >
              Delete Account
            </button>
          </div>
        </div>
      </div>
    </div>

    <div
      id="deleteModal"
      class="hidden modal-overlay fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm"
    >
      <div class="modal-content w-full max-w-md rounded-2xl border border-[#27272a] bg-[#18181b] p-10 text-center text-white shadow-[0_20px_25px_-5px_rgba(0,0,0,0.1),0_10px_10px_-5px_rgba(0,0,0,0.04)]">
        <h3 class="text-xl font-semibold text-[#ef4444]">Delete Account?</h3>
        <p class="mt-3 text-sm text-[#a1a1aa]">This action cannot be undone.</p>

        <div id="passwordConfirm" class="my-4">
          <input
            type="password"
            id="deletePassword"
            class="edit-input w-full rounded-lg border border-[#3f3f46] bg-[#0f0f11] px-4 py-3 text-sm text-white transition focus:border-[#ffe000] focus:outline-none focus:ring-2 focus:ring-[#ffe000]/20"
            placeholder="Enter password to confirm"
          />
        </div>
        <p
          id="deleteError"
          class="mt-3 text-sm text-[#fc8181]"
          style="display: none"
        ></p>

        <div class="modal-actions mt-6 flex justify-center gap-3">
          <button
            onclick="closeDeleteModal()"
            class="secondary rounded-lg border border-[#3f3f46] px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#a1a1aa] transition hover:border-[#71717a] hover:bg-white/5 hover:text-white"
          >
            Cancel
          </button>
          <button
            onclick="confirmDelete()"
            class="primary rounded-lg bg-[#fc8181] px-6 py-3 text-xs font-semibold uppercase tracking-wider text-[#232326] transition hover:bg-[#f87171]"
          >
            Delete Forever
          </button>
        </div>
      </div>
    </div>

    <Footer />

    <script is:inline>
      const alertBaseClass =
        "alert-box mb-6 rounded-lg border-l-4 px-4 py-3 text-sm font-medium";
      const alertClasses = {
        "alert-warning": "border-[#ffd700] bg-[#ffd700]/10 text-[#ffd700]",
        "alert-success": "border-[#68d391] bg-[#68d391]/10 text-[#68d391]",
        "alert-error": "border-[#fc8181] bg-[#fc8181]/10 text-[#fc8181]",
      };

      const DEFAULT_AVATAR_URL = "https://ui-avatars.com/api/?background=random&name=";
      let currentUser = null;
      let isGoogleUser = false;

      async function checkSession() {
        // 1. Check LocalStorage first
        const storedUser = localStorage.getItem("user");
        let localUser = null;
        if (storedUser) {
          localUser = JSON.parse(storedUser);
        }

        // 2. Always validate with Backend to ensure account still exists
        try {
          const response = await fetch(`${CONFIG.getApiBaseUrl()}/users/profile`, {
            method: "GET",
            credentials: "include",
          });

          if (response.ok) {
            const googleData = await response.json();

            const user = {
              id: googleData.id,
              name: googleData.name,
              email: googleData.email,
              picture: googleData.picture,
              program: googleData.program || "N/A",
              level: googleData.level || "N/A",
            };
            // If program is "N/A (Google Login)" it's definitely Google
            if (user.program === "N/A (Google Login)") {
              user.isGoogle = true;
            }

            // Update localStorage with fresh data
            localStorage.setItem("user", JSON.stringify(user));
            initDashboard(user);
          } else {
            // Backend session invalid or user deleted
            console.warn(`Backend session invalid: ${response.status}`);
            document.getElementById("loading").innerHTML = `
              <h2 class="text-xl font-semibold text-[#fc8181]">Session Error (${response.status})</h2>
              <p class="mt-2 text-sm text-[#a1a1aa]">Could not verify your session with the backend.</p>
              <p class="mt-2 text-sm text-[#a1a1aa]">Please <a href="signin.html" data-astro-prefetch class="font-semibold text-[#ffe000]">sign in again</a>.</p>
            `;
            localStorage.removeItem("user");
            // window.location.href = "signin.html"; // DISABLED FOR DEBUGGING
          }
        } catch (error) {
          console.error("Session check failed:", error);
          document.getElementById("loading").innerHTML = `
              <h2 class="text-xl font-semibold text-[#fc8181]">Connection Error</h2>
              <p class="mt-2 text-sm text-[#a1a1aa]">${error.message}</p>
              <p class="mt-2 text-sm text-[#a1a1aa]">Please <a href="signin.html" data-astro-prefetch class="font-semibold text-[#ffe000]">sign in again</a>.</p>
          `;
          localStorage.removeItem("user");
          // window.location.href = "signin.html"; // DISABLED FOR DEBUGGING
        }
      }

      function initDashboard(user) {
        console.log("DEBUG: Init Dashboard with user:", user);
        currentUser = user;
        // Robust check: If user has no password OR is linked to Google, treat as OAuth user for deletion UI
        isGoogleUser = !user.has_password || user.google_linked;
        console.log("DEBUG: isGoogleUser derived as:", isGoogleUser);

        document.getElementById("loading").style.display = "none";
        document.getElementById("dashboardContent").style.display = "block";

        // Fill Data
        document.getElementById("displayProgram").textContent = user.program || "N/A";
        document.getElementById("displayLevel").textContent = user.level || "N/A";

        // Update navbar profile
        document.getElementById("navbarProfile").style.display = "flex";
        document.getElementById("navbarProfileName").textContent = user.name.split(" ")[0]; // First name
        if (user.picture) {
          document.getElementById("navbarProfilePic").src = user.picture;
        } else {
          document.getElementById("navbarProfilePic").src = DEFAULT_AVATAR_URL + user.name;
        }

        // Check URL for actions
        const urlParams = new URLSearchParams(window.location.search);
        const action = urlParams.get("action");

        // Force Update if info missing OR action is complete_profile
        if (action === "complete_profile" || !user.program || user.program === "N/A" || user.program === "N/A (Google Login)") {
          showNotification("Please complete your profile details.", "alert-warning");
          // Show edit mode immediately
          toggleEditMode();
        }
      }

      function toggleEditMode() {
        const viewMode = document.getElementById("viewMode");
        const editMode = document.getElementById("editMode");
        const editBtn = document.getElementById("editBtn");
        const saveBtn = document.getElementById("saveBtn");
        const cancelBtn = document.getElementById("cancelBtn");

        if (editMode.classList.contains("hidden")) {
          // Show Edit
          viewMode.classList.add("hidden");
          editMode.classList.remove("hidden");
          editBtn.classList.add("hidden");
          saveBtn.classList.remove("hidden");
          // Only show Cancel if it's not a forced completion (checking URL params again is safest or relying on user state)
          // For simplicity, we allow cancel but the notification persists
          cancelBtn.classList.remove("hidden");

          // Fill inputs
          const currentProg = document.getElementById("displayProgram").textContent;
          document.getElementById("editProgram").value =
            currentProg === "N/A" || currentProg === "N/A (Google Login)" ? "" : currentProg;

          const currentLvl = document.getElementById("displayLevel").textContent;
          document.getElementById("editLevel").value = currentLvl === "N/A" ? "LOW" : currentLvl;
        } else {
          // Show View
          editMode.classList.add("hidden");
          viewMode.classList.remove("hidden");
          saveBtn.classList.add("hidden");
          cancelBtn.classList.add("hidden");
          editBtn.classList.remove("hidden");
          document.getElementById("notification").style.display = "none";
        }
      }

      async function saveProfile() {
        const newProgram = document.getElementById("editProgram").value;
        const newLevel = document.getElementById("editLevel").value;
        const saveBtn = document.getElementById("saveBtn");

        saveBtn.textContent = "Saving...";
        saveBtn.disabled = true;

        try {
          // Use /api/users/:id endpoint
          const response = await fetch(`${CONFIG.getApiBaseUrl()}/api/users/${currentUser.id}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ programme: newProgram, experience_level: newLevel }), // Note: backend expects 'programme' not 'program'
            credentials: "include",
          });

          if (response.ok) {
            const updatedUser = await response.json();

            // Transform backend response to frontend format if needed
            // Backend returns { programme: ..., experience_level: ... }
            // Frontend expects { program: ..., level: ... }
            // Let's manually map it since getAllUsers might not return the same structure as getCurrentUser logic?
            // Actually updatedUser from backend is the raw model.
            const mappedUser = {
              ...currentUser,
              program: updatedUser.programme,
              level: updatedUser.experience_level,
            };

            // Update state
            currentUser = mappedUser;
            localStorage.setItem("user", JSON.stringify(mappedUser));

            // Update UI
            document.getElementById("displayProgram").textContent = mappedUser.program;
            document.getElementById("displayLevel").textContent = mappedUser.level;

            showNotification("Profile updated successfully!", "alert-success");

            // Clean URL if it had action param
            const url = new URL(window.location);
            if (url.searchParams.has("action")) {
              url.searchParams.delete("action");
              window.history.replaceState({}, "", url);
            }

            toggleEditMode();
          } else {
            throw new Error("Failed to update");
          }
        } catch (error) {
          console.error(error);
          showNotification("Error updating profile.", "alert-warning");
        } finally {
          saveBtn.textContent = "Save Changes";
          saveBtn.disabled = false;
        }
      }

      // --- DELETE LOGIC ---
      function showDeleteModal() {
        const modal = document.getElementById("deleteModal");
        const passField = document.getElementById("passwordConfirm");
        const errorMsg = document.getElementById("deleteError");
        if (errorMsg) errorMsg.style.display = "none";

        // Hide password field for Google Users
        if (isGoogleUser) {
          passField.style.display = "none";
        } else {
          passField.style.display = "block";
        }
        modal.classList.remove("hidden");
      }

      function closeDeleteModal() {
        document.getElementById("deleteModal").classList.add("hidden");
      }

      async function confirmDelete() {
        const password = document.getElementById("deletePassword").value;
        const errorMsg = document.getElementById("deleteError");

        // Basic validation for non-Google users
        if (!isGoogleUser && !password) {
          errorMsg.textContent = "Password is required.";
          errorMsg.style.display = "block";
          return;
        }

        try {
          // Use DELETE /api/users/:id
          const response = await fetch(`${CONFIG.getApiBaseUrl()}/api/users/${currentUser.id}`, {
            method: "DELETE",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ password: password }),
            credentials: "include",
          });

          if (response.ok || response.status === 204) {
            // Success
            localStorage.removeItem("user");
            window.location.href = "index.html";
          } else {
            const data = await response.json();
            errorMsg.textContent = data.error || "Failed to delete account.";
            errorMsg.style.display = "block";
          }
        } catch (e) {
          console.error(e);
          errorMsg.textContent = "An error occurred.";
          errorMsg.style.display = "block";
        }
      }

      async function handleLogout() {
        localStorage.removeItem("user");
        // Call backend logout
        try {
          await fetch(`${CONFIG.getApiBaseUrl()}/api/auth/logout`);
        } catch (e) {}
        window.location.href = "signin.html";
      }

      function showNotification(msg, type) {
        const notif = document.getElementById("notification");
        const typeClasses = alertClasses[type] || "";
        notif.textContent = msg;
        notif.className = `${alertBaseClass} ${typeClasses}`;
        notif.style.display = "block";
        // Don't auto-hide if it's a warning (like profile completion)
        if (type !== "alert-warning") {
          setTimeout(() => (notif.style.display = "none"), 3000);
        }
      }

      // Initialize
      checkSession();
    </script>
  </body>
</html>

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="styles/styles.css" />
    <link rel="stylesheet" href="styles/responsive.css" />
    <link rel="icon" type="image/x-icon" href="/images/logo.png" />
    <script is:inline src="scripts/config.js"></script>

    <style is:global>
        @import url("https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap");

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            background: #ffe000;
            margin: 0;
            font-family: 'Inter', sans-serif;
        }

        .auth-container {
            background: linear-gradient(180deg, #232326 0%, #1f1f22 100%);
            padding: 32px;
            border-radius: 12px;
            box-shadow: 0 18px 50px rgba(0, 0, 0, 0.45);
            width: 100%;
            max-width: 420px;
            text-align: center;
            color: #fcfbf8;
            border: 1px solid rgba(255, 255, 255, 0.03);
        }

        .auth-container h2 {
            margin-bottom: 18px;
            color: #ffe000;
        }

        .auth-input {
            width: 100%;
            padding: 12px 14px;
            margin: 10px 0;
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.04);
            background: #151518;
            color: #f7f7f7;
            box-sizing: border-box;
            font-size: 0.95rem;
        }

        .auth-input:focus {
            outline: none;
            border-color: #ffe000;
            box-shadow: 0 10px 30px rgba(255, 224, 0, 0.08);
            transform: translateY(-1px);
        }

        .auth-btn {
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            border: none;
            font-weight: 700;
            background: linear-gradient(135deg, #ffe000 0%, #ffc700 100%);
            color: #232326;
            box-shadow: 0 12px 30px rgba(255, 224, 0, 0.12);
            cursor: pointer;
        }

        .auth-btn:hover {
            transform: translateY(-3px);
        }

        .error-msg {
            color: #ffb4b4;
            font-size: 0.95rem;
            margin-top: 10px;
            display: none;
        }

        .success-msg {
            color: #9ff3b0;
            font-size: 0.95rem;
            margin-top: 10px;
            display: none;
        }

        .step {
            display: none;
        }

        .step.active {
            display: block;
        }
    </style>

    <title>Reset Password - LNU AI Society</title>
</head>

<body>
    <div class="auth-container">
        <a href="/"><img src="/images/logo.png" alt="Logo" style="width: 60px; margin-bottom: 20px;" /></a>
        <h2>Reset Password</h2>

        <!-- Step 1: Enter Email -->
        <div id="step1" class="step active">
            <p>Enter your email to receive a reset code.</p>
            <input type="email" id="resetEmail" class="auth-input" placeholder="Email Address" required />
            <button onclick="sendResetCode()" class="auth-btn">Send Code</button>
        </div>

        <!-- Step 2: Enter Code -->
        <div id="step2" class="step">
            <p>Enter the 6-digit code sent to your email.</p>
            <input type="text" id="resetCode" class="auth-input" placeholder="123456" required />
            <button onclick="verifyCode()" class="auth-btn">Verify Code</button>
        </div>

        <!-- Step 3: New Password -->
        <div id="step3" class="step">
            <p>Enter your new password.</p>
            <input type="password" id="newPassword" class="auth-input" placeholder="New Password" required />
            <button onclick="resetPassword()" class="auth-btn">Reset Password</button>
        </div>

        <p id="message" class="error-msg"></p>
        <p id="successMessage" class="success-msg"></p>

        <p style="margin-top: 20px; font-size: 0.9rem;">
            <a href="signin.html" style="color: #ffffff; text-decoration: none; font-weight:600;">Back to Sign In</a>
        </p>
    </div>

    <script is:inline>
        let userEmail = "";
        let verifiedCode = "";

        function showMessage(msg, isError = true) {
            const msgEl = document.getElementById(isError ? "message" : "successMessage");
            const otherEl = document.getElementById(isError ? "successMessage" : "message");

            msgEl.textContent = msg;
            msgEl.style.display = "block";
            otherEl.style.display = "none";
        }

        async function sendResetCode() {
            const email = document.getElementById("resetEmail").value;
            if (!email) return showMessage("Please enter your email.");

            try {
                const response = await fetch(`${CONFIG.getApiBaseUrl()}/users/forgot-password`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ email: email })
                });

                if (response.ok) {
                    userEmail = email;
                    showMessage("Code sent! Please check your email.", false);
                    document.getElementById("step1").classList.remove("active");
                    document.getElementById("step2").classList.add("active");
                } else {
                    const data = await response.json();
                    showMessage(data.error || "Failed to send code.");
                }
            } catch (e) {
                showMessage("An error occurred.");
            }
        }

        async function verifyCode() {
            const code = document.getElementById("resetCode").value;
            if (!code) return showMessage("Please enter the code.");

            try {
                const response = await fetch(`${CONFIG.getApiBaseUrl()}/users/verify-reset-code`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ email: userEmail, code: code })
                });

                if (response.ok) {
                    verifiedCode = code;
                    showMessage("Code verified!", false);
                    document.getElementById("step2").classList.remove("active");
                    document.getElementById("step3").classList.add("active");
                } else {
                    const data = await response.json();
                    showMessage(data.error || "Invalid code.");
                }
            } catch (e) {
                showMessage("An error occurred.");
            }
        }

        async function resetPassword() {
            const password = document.getElementById("newPassword").value;
            if (!password) return showMessage("Please enter a new password.");

            try {
                const response = await fetch(`${CONFIG.getApiBaseUrl()}/users/reset-password`, {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ email: userEmail, code: verifiedCode, newPassword: password })
                });

                if (response.ok) {
                    showMessage("Password reset successfully! Redirecting...", false);
                    setTimeout(() => window.location.href = "signin.html", 2000);
                } else {
                    const data = await response.json();
                    showMessage(data.error || "Failed to reset password.");
                }
            } catch (e) {
                showMessage("An error occurred.");
            }
        }
    </script>
</body>

</html>

---
import '../styles/global.css';
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/images/logo.png" />
    <script is:inline src="scripts/config.js"></script>

    <title>Reset Password - LNU AI Society</title>
  </head>

  <body class="flex min-h-screen items-center justify-center bg-[#ffe000] px-6 py-12 font-sans text-[#232326]">
    <div class="auth-container w-full max-w-md rounded-2xl border border-white/5 bg-gradient-to-b from-[#232326] to-[#1f1f22] p-8 text-center text-[#fcfbf8] shadow-[0_18px_50px_rgba(0,0,0,0.45)]">
      <a href="/" data-astro-prefetch>
        <img src="/images/logo.png" alt="Logo" class="mx-auto mb-5 w-14" />
      </a>
      <h2 class="text-xl font-semibold text-[#ffe000]">Reset Password</h2>

      <!-- Step 1: Enter Email -->
      <div id="step1" class="step mt-6 space-y-4">
        <p class="text-sm text-[#b0b0b0]">
          Enter your email to receive a reset code.
        </p>
        <input
          type="email"
          id="resetEmail"
          class="auth-input w-full rounded-xl border border-white/10 bg-[#151518] px-4 py-3 text-sm text-[#f7f7f7] transition focus:border-[#ffe000] focus:outline-none focus:ring-2 focus:ring-[#ffe000]/20"
          placeholder="Email Address"
          required
        />
        <button
          onclick="sendResetCode()"
          class="auth-btn w-full rounded-xl bg-gradient-to-br from-[#ffe000] to-[#ffc700] px-4 py-3 text-sm font-bold text-[#232326] shadow-[0_12px_30px_rgba(255,224,0,0.12)] transition hover:-translate-y-0.5"
        >
          Send Code
        </button>
      </div>

      <!-- Step 2: Enter Code -->
      <div id="step2" class="step mt-6 hidden space-y-4">
        <p class="text-sm text-[#b0b0b0]">
          Enter the 6-digit code sent to your email.
        </p>
        <input
          type="text"
          id="resetCode"
          class="auth-input w-full rounded-xl border border-white/10 bg-[#151518] px-4 py-3 text-sm text-[#f7f7f7] transition focus:border-[#ffe000] focus:outline-none focus:ring-2 focus:ring-[#ffe000]/20"
          placeholder="123456"
          required
        />
        <button
          onclick="verifyCode()"
          class="auth-btn w-full rounded-xl bg-gradient-to-br from-[#ffe000] to-[#ffc700] px-4 py-3 text-sm font-bold text-[#232326] shadow-[0_12px_30px_rgba(255,224,0,0.12)] transition hover:-translate-y-0.5"
        >
          Verify Code
        </button>
      </div>

      <!-- Step 3: New Password -->
      <div id="step3" class="step mt-6 hidden space-y-4">
        <p class="text-sm text-[#b0b0b0]">Enter your new password.</p>
        <input
          type="password"
          id="newPassword"
          class="auth-input w-full rounded-xl border border-white/10 bg-[#151518] px-4 py-3 text-sm text-[#f7f7f7] transition focus:border-[#ffe000] focus:outline-none focus:ring-2 focus:ring-[#ffe000]/20"
          placeholder="New Password"
          required
        />
        <button
          onclick="resetPassword()"
          class="auth-btn w-full rounded-xl bg-gradient-to-br from-[#ffe000] to-[#ffc700] px-4 py-3 text-sm font-bold text-[#232326] shadow-[0_12px_30px_rgba(255,224,0,0.12)] transition hover:-translate-y-0.5"
        >
          Reset Password
        </button>
      </div>

      <p id="message" class="error-msg mt-4 text-sm text-[#ffb4b4]" style="display: none"></p>
      <p id="successMessage" class="success-msg mt-4 text-sm text-[#9ff3b0]" style="display: none"></p>

      <p class="mt-6 text-sm text-[#cfcfcf]">
        <a href="signin.html" data-astro-prefetch class="font-semibold text-white">Back to Sign In</a>
      </p>
    </div>

    <script is:inline>
      let userEmail = "";
      let verifiedCode = "";

      function showMessage(msg, isError = true) {
        const msgEl = document.getElementById(
          isError ? "message" : "successMessage",
        );
        const otherEl = document.getElementById(
          isError ? "successMessage" : "message",
        );

        msgEl.textContent = msg;
        msgEl.style.display = "block";
        otherEl.style.display = "none";
      }

      async function sendResetCode() {
        const email = document.getElementById("resetEmail").value;
        if (!email) return showMessage("Please enter your email.");

        try {
          const response = await fetch(
            `${CONFIG.getApiBaseUrl()}/users/forgot-password`,
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ email: email }),
            },
          );

          if (response.ok) {
            userEmail = email;
            showMessage("Code sent! Please check your email.", false);
            document.getElementById("step1").classList.add("hidden");
            document.getElementById("step2").classList.remove("hidden");
          } else {
            const data = await response.json();
            showMessage(data.error || "Failed to send code.");
          }
        } catch (e) {
          showMessage("An error occurred.");
        }
      }

      async function verifyCode() {
        const code = document.getElementById("resetCode").value;
        if (!code) return showMessage("Please enter the code.");

        try {
          const response = await fetch(
            `${CONFIG.getApiBaseUrl()}/users/verify-reset-code`,
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                email: userEmail,
                code: code,
              }),
            },
          );

          if (response.ok) {
            verifiedCode = code;
            showMessage("Code verified!", false);
            document.getElementById("step2").classList.add("hidden");
            document.getElementById("step3").classList.remove("hidden");
          } else {
            const data = await response.json();
            showMessage(data.error || "Invalid code.");
          }
        } catch (e) {
          showMessage("An error occurred.");
        }
      }

      async function resetPassword() {
        const password = document.getElementById("newPassword").value;
        if (!password) return showMessage("Please enter a new password.");

        try {
          const response = await fetch(
            `${CONFIG.getApiBaseUrl()}/users/reset-password`,
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                email: userEmail,
                code: verifiedCode,
                newPassword: password,
              }),
            },
          );

          if (response.ok) {
            showMessage("Password reset successfully! Redirecting...", false);
            setTimeout(() => (window.location.href = "signin.html"), 2000);
          } else {
            const data = await response.json();
            showMessage(data.error || "Failed to reset password.");
          }
        } catch (e) {
          showMessage("An error occurred.");
        }
      }
    </script>
  </body>
</html>

---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/images/logo.png" />

    <title>Reset Password - LNU AI Society</title>
  </head>

  <body class="flex min-h-screen flex-col bg-[#ffe000] font-sans text-[#232326]">
    <Nav />

    <div class="container mx-auto flex-1 px-6 pb-32 pt-28 md:px-10">
      <div class="hero text-center">
        <h1 class="text-4xl font-bold md:text-5xl">
          Join the LNU AI Society
        </h1>
        <p class="mx-auto mt-4 max-w-[85ch] text-base font-medium md:text-lg">
          Become part of our growing community of AI enthusiasts at Linnaeus
          University.
          <span class="highlight font-semibold">Shape the future</span> with us.
        </p>
      </div>

      <div class="card signup-card mx-auto mt-10 max-w-[720px] rounded-2xl border border-white/5 bg-gradient-to-b from-[#1f1f23] to-[#222226] p-9 text-[#fcfbf8] shadow-[0_12px_40px_rgba(0,0,0,0.45)]">
        <h2 class="text-xl font-semibold text-[#ffe000]">
          Reset Your Password
        </h2>

        <form class="signup-form mt-4">
          <div class="form-group">
            <label class="mb-2 block text-sm font-semibold text-[#cfcfcf]" for="email">
              Email Address
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full rounded-xl border border-white/10 bg-[#151518] px-4 py-3 text-sm text-[#f7f7f7] transition focus:border-[#ffe000] focus:outline-none focus:ring-2 focus:ring-[#ffe000]/20"
            />
            <small class="mt-2 block text-xs text-[#9aa0a6]">
              The email address you entered when registering.
            </small>
          </div>

          <!--NOTE: we should probably assign ID's like new-password and new-password-confirm, etc. here-->
          <div class="form-group mt-4">
            <label class="mb-2 block text-sm font-semibold text-[#cfcfcf]" for="password">
              New Password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              class="w-full rounded-xl border border-white/10 bg-[#151518] px-4 py-3 text-sm text-[#f7f7f7] transition focus:border-[#ffe000] focus:outline-none focus:ring-2 focus:ring-[#ffe000]/20"
            />
            <small class="mt-2 block text-xs text-[#9aa0a6]">
              Enter your new password.
            </small>
          </div>

          <div class="form-group mt-4">
            <label class="mb-2 block text-sm font-semibold text-[#cfcfcf]" for="password">
              Confirm Password
            </label>
            <input
              type="password"
              id="password"
              name="password"
              required
              class="w-full rounded-xl border border-white/10 bg-[#151518] px-4 py-3 text-sm text-[#f7f7f7] transition focus:border-[#ffe000] focus:outline-none focus:ring-2 focus:ring-[#ffe000]/20"
            />
            <small class="mt-2 block text-xs text-[#9aa0a6]">
              Confirm your new password.
            </small>
          </div>

          <button
            type="submit"
            class="primary full-width mt-6 w-full rounded-xl bg-gradient-to-br from-[#ffe000] to-[#ffc700] px-4 py-3 text-sm font-bold text-[#232326] shadow-[0_12px_30px_rgba(255,224,0,0.12)] transition hover:-translate-y-0.5"
          >
            Reset My Password
          </button>
        </form>

        <div class="signup-footer mt-4 text-sm text-[#cfcfcf]">
          <p>
            Re-read our
            <a href="#" class="link font-semibold text-[#ffe000]">
              Terms of Service
            </a>
            and
            <a href="#" class="link font-semibold text-[#ffe000]">
              Privacy Policy
            </a>
          </p>
        </div>
      </div>
    </div>

    <Footer />
    <script is:inline src="scripts/navbar.js"></script>
    <script is:inline src="scripts/hamburger.js"></script>
  </body>
</html>

---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en" class="h-full">
    <head>
        <script is:inline>
            if (localStorage.getItem("user")) {
                window.location.href = "dashboard.html";
            }
        </script>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/x-icon" href="/images/logo.png" />
        <script is:inline src="scripts/config.js"></script>

        <title>Sign Up - LNU AI Society</title>
    </head>

    <body
        class="flex min-h-screen flex-col bg-[#ffe000] font-sans text-[#232326]"
    >
        <Nav />

        <div class="container mx-auto flex-1 px-6 pb-32 pt-28 md:px-10">
            <div class="hero text-center">
                <h1 class="text-4xl font-bold md:text-5xl">
                    Join the LNU AI Society
                </h1>
                <p
                    class="mx-auto mt-4 max-w-[85ch] text-base font-medium md:text-lg"
                >
                    Become part of our growing community of AI enthusiasts at
                    Linnaeus University. Shape the future with us.
                </p>
            </div>

            <div
                class="card signup-card mx-auto mt-10 max-w-[720px] rounded-2xl border border-white/5 bg-gradient-to-b from-[#1f1f23] to-[#222226] p-9 text-[#fcfbf8] shadow-[0_12px_40px_rgba(0,0,0,0.45)]"
            >
                <h2 class="text-xl font-semibold text-[#ffe000]">
                    Create Your Account
                </h2>
                <a
                    href="#"
                    id="googleSignupBtn"
                    class="google-btn mt-4 flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-br from-[#4285f4] to-[#2a66e6] px-4 py-3 text-sm font-bold text-white shadow-[0_8px_20px_rgba(42,102,230,0.18)] transition hover:-translate-y-0.5"
                    >Sign up with Google</a
                >
                <div
                    class="divider my-4 flex items-center gap-3 text-xs uppercase tracking-widest text-[#9aa0a6]"
                >
                    <span class="h-px flex-1 bg-white/10"></span>
                    OR
                    <span class="h-px flex-1 bg-white/10"></span>
                </div>

                <div id="signupMessage" class="message-box hidden"></div>

                <form class="signup-form" id="signupForm">
                    <div class="form-row grid grid-cols-1 gap-4 md:grid-cols-2">
                        <div class="form-group">
                            <label
                                class="mb-2 block text-sm font-semibold text-[#cfcfcf]"
                            >
                                First Name
                            </label>
                            <input
                                type="text"
                                id="firstName"
                                required
                                class="w-full rounded-xl border border-white/10 bg-[#151518] px-4 py-3 text-sm text-[#f7f7f7] transition focus:border-[#ffe000] focus:outline-none focus:ring-2 focus:ring-[#ffe000]/20"
                            />
                        </div>
                        <div class="form-group">
                            <label
                                class="mb-2 block text-sm font-semibold text-[#cfcfcf]"
                            >
                                Last Name
                            </label>
                            <input
                                type="text"
                                id="lastName"
                                required
                                class="w-full rounded-xl border border-white/10 bg-[#151518] px-4 py-3 text-sm text-[#f7f7f7] transition focus:border-[#ffe000] focus:outline-none focus:ring-2 focus:ring-[#ffe000]/20"
                            />
                        </div>
                    </div>
                    <div class="form-group mt-4">
                        <label
                            class="mb-2 block text-sm font-semibold text-[#cfcfcf]"
                        >
                            Email Address
                        </label>
                        <input
                            type="email"
                            id="email"
                            required
                            class="w-full rounded-xl border border-white/10 bg-[#151518] px-4 py-3 text-sm text-[#f7f7f7] transition focus:border-[#ffe000] focus:outline-none focus:ring-2 focus:ring-[#ffe000]/20"
                        />
                        <small class="mt-2 block text-xs text-[#9aa0a6]">
                            We'll send a verification code to this email.
                        </small>
                    </div>
                    <div class="form-group mt-4">
                        <label
                            class="mb-2 block text-sm font-semibold text-[#cfcfcf]"
                        >
                            Password
                        </label>
                        <input
                            type="password"
                            id="password"
                            required
                            class="w-full rounded-xl border border-white/10 bg-[#151518] px-4 py-3 text-sm text-[#f7f7f7] transition focus:border-[#ffe000] focus:outline-none focus:ring-2 focus:ring-[#ffe000]/20"
                        />
                    </div>
                    <div class="form-group mt-4">
                        <label
                            class="mb-2 block text-sm font-semibold text-[#cfcfcf]"
                        >
                            Programme
                        </label>
                        <input
                            type="text"
                            id="programme"
                            required
                            class="w-full rounded-xl border border-white/10 bg-[#151518] px-4 py-3 text-sm text-[#f7f7f7] transition focus:border-[#ffe000] focus:outline-none focus:ring-2 focus:ring-[#ffe000]/20"
                        />
                    </div>

                    <div class="form-group mt-4">
                        <label
                            class="mb-2 block text-sm font-semibold text-[#cfcfcf]"
                        >
                            AI/ML Experience
                        </label>
                        <div class="radio-group flex flex-wrap gap-3">
                            <label class="radio-option flex items-center gap-2">
                                <input
                                    type="radio"
                                    name="experience"
                                    value="beginner"
                                    required
                                    class="peer sr-only"
                                />
                                <span
                                    class="radio-label inline-flex cursor-pointer rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-[#cfcfcf] transition peer-checked:border-[#ffe000]/60 peer-checked:bg-gradient-to-br peer-checked:from-[#ffe000] peer-checked:to-[#ffc700] peer-checked:text-[#232326] peer-checked:shadow-[0_8px_18px_rgba(255,224,0,0.12)]"
                                    >Beginner</span
                                >
                            </label>
                            <label class="radio-option flex items-center gap-2">
                                <input
                                    type="radio"
                                    name="experience"
                                    value="intermediate"
                                    class="peer sr-only"
                                />
                                <span
                                    class="radio-label inline-flex cursor-pointer rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-[#cfcfcf] transition peer-checked:border-[#ffe000]/60 peer-checked:bg-gradient-to-br peer-checked:from-[#ffe000] peer-checked:to-[#ffc700] peer-checked:text-[#232326] peer-checked:shadow-[0_8px_18px_rgba(255,224,0,0.12)]"
                                    >Intermediate</span
                                >
                            </label>
                            <label class="radio-option flex items-center gap-2">
                                <input
                                    type="radio"
                                    name="experience"
                                    value="advanced"
                                    class="peer sr-only"
                                />
                                <span
                                    class="radio-label inline-flex cursor-pointer rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm font-semibold text-[#cfcfcf] transition peer-checked:border-[#ffe000]/60 peer-checked:bg-gradient-to-br peer-checked:from-[#ffe000] peer-checked:to-[#ffc700] peer-checked:text-[#232326] peer-checked:shadow-[0_8px_18px_rgba(255,224,0,0.12)]"
                                    >Advanced</span
                                >
                            </label>
                        </div>
                    </div>

                    <!-- Terms checkbox removed (visual-only request) -->

                    <button
                        type="submit"
                        class="primary cursor-pointer full-width mt-6 w-full rounded-xl bg-gradient-to-br from-[#ffe000] to-[#ffc700] px-4 py-3 text-sm font-bold text-[#232326] shadow-[0_12px_30px_rgba(255,224,0,0.12)] transition hover:-translate-y-0.5"
                        id="signupBtn"
                    >
                        Join The Community
                    </button>
                </form>

                <div
                    class="signup-footer mt-4 text-center text-sm text-[#cfcfcf]"
                >
                    <p>
                        Already have an account?
                        <a
                            href="signin.html"
                            data-astro-prefetch
                            class="link font-semibold text-[#ffe000]"
                        >
                            Sign in here
                        </a>
                    </p>
                </div>
            </div>
        </div>

        <Footer />

        <script is:inline>
            const messageBaseClass =
                "message-box mt-4 rounded-lg border px-4 py-3 text-sm";
            const messageSuccessClass = `${messageBaseClass} border-[#68d391] bg-[#153126] text-[#9ff3b0]`;
            const messageErrorClass = `${messageBaseClass} border-[#ff8181] bg-[#3a1f1f] text-[#ffb4b4]`;

            // Set Google Signup URL dynamically
            document.getElementById("googleSignupBtn").href =
                `${CONFIG.getApiBaseUrl()}/oauth2/authorization/google`;

            document
                .getElementById("signupForm")
                .addEventListener("submit", async function (e) {
                    e.preventDefault();

                    const btn = document.getElementById("signupBtn");
                    const msgBox = document.getElementById("signupMessage");
                    btn.textContent = "Creating Account...";
                    btn.disabled = true;
                    msgBox.style.display = "none";

                    const firstName =
                        document.getElementById("firstName").value;
                    const lastName = document.getElementById("lastName").value;
                    const email = document.getElementById("email").value;
                    const password = document.getElementById("password").value;
                    const programme =
                        document.getElementById("programme").value;
                    const experienceInput = document.querySelector(
                        'input[name="experience"]:checked',
                    ).value;

                    let backendLevel = "LOW";
                    if (experienceInput === "intermediate")
                        backendLevel = "MID";
                    if (experienceInput === "advanced") backendLevel = "HIGH";

                    try {
                        const response = await fetch(
                            `${CONFIG.getApiBaseUrl()}/users/new_member`,
                            {
                                method: "POST",
                                headers: { "Content-Type": "application/json" },
                                body: JSON.stringify({
                                    name: firstName + " " + lastName,
                                    email: email,
                                    password: password,
                                    program: programme,
                                    level: backendLevel,
                                }),
                            },
                        );

                        if (response.ok) {
                            // SUCCESS: Save email to memory so verify.html knows who it is
                            localStorage.setItem("pendingEmail", email);
                            msgBox.textContent =
                                "Account created! Sending verification email...";
                            msgBox.className = messageSuccessClass;
                            msgBox.style.display = "block";
                            setTimeout(() => {
                                window.location.href = "verify.html";
                            }, 1500);
                        } else {
                            const errorData = await response.json();
                            const errorMsg =
                                errorData.message ||
                                "Email may already be taken";
                            throw new Error(errorMsg);
                        }
                    } catch (error) {
                        msgBox.textContent = error.message;
                        msgBox.className = messageErrorClass;
                        msgBox.style.display = "block";
                        btn.textContent = "Join The Community";
                        btn.disabled = false;
                    }
                });
        </script>

        <script is:inline src="scripts/navbar.js"></script>
    </body>
</html>

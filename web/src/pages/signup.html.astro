---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">

<head>
  <script is:inline>
    if (localStorage.getItem("user")) {
      window.location.href = "dashboard.html";
    }
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="styles/styles.css" />
  <link rel="stylesheet" href="styles/responsive.css" />
  <link rel="icon" type="image/x-icon" href="/images/logo.png" />
  <script is:inline src="scripts/config.js"></script>

  <style is:global>
    @import url("https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap");

    /* Modern signup card styles */
    .signup-card {
      max-width: 720px;
      margin: 3rem auto;
      padding: 2.25rem;
      border-radius: 14px;
      background: linear-gradient(180deg, #1f1f23 0%, #222226 100%);
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.45);
      border: 1px solid rgba(255, 255, 255, 0.03);
    }

    .signup-card h2 {
      margin-top: 0;
      margin-bottom: 0.75rem;
      color: #ffe000;
      font-size: 1.6rem;
    }

    .google-btn {
      background: linear-gradient(135deg, #4285f4 0%, #2a66e6 100%);
      color: white;
      text-decoration: none;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 12px 16px;
      border-radius: 10px;
      font-weight: 700;
      margin-bottom: 12px;
      width: 100%;
      box-sizing: border-box;
      border: none;
      box-shadow: 0 8px 20px rgba(42, 102, 230, 0.18);
    }

    .google-btn:hover {
      transform: translateY(-2px);
    }

    .divider {
      text-align: center;
      margin: 14px 0 18px 0;
      color: #9aa0a6;
      font-size: 0.9rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
    }

    .divider::before,
    .divider::after {
      content: "";
      flex: 1;
      border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    }

    .signup-form {
      display: block;
      gap: 12px;
    }

    .form-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .form-group {
      margin-bottom: 12px;
    }

    .form-group label {
      display: block;
      margin-bottom: 6px;
      color: #cfcfcf;
      font-weight: 600;
      font-size: 0.9rem;
    }

    input[type="text"],
    input[type="email"],
    input[type="password"],
    select {
      width: 100%;
      padding: 12px 14px;
      border-radius: 10px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      background: #151518;
      color: #f7f7f7;
      box-sizing: border-box;
      font-size: 0.95rem;
      transition: box-shadow .15s ease, border-color .15s ease, transform .08s ease;
    }

    input:focus,
    select:focus {
      outline: none;
      border-color: #ffe000;
      box-shadow: 0 6px 18px rgba(255, 224, 0, 0.08);
      transform: translateY(-1px);
    }

    .radio-group {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .radio-option {
      display: flex;
      align-items: center;
      gap: 8px;
      color: #cfcfcf;
    }

    /* Custom radio pills */
    .radio-option input[type="radio"] {
      display: none;
    }

    .radio-option .radio-label {
      display: inline-block;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.02);
      color: #cfcfcf;
      border: 1px solid rgba(255, 255, 255, 0.04);
      cursor: pointer;
      transition: all 0.18s ease;
      font-weight: 600;
      font-size: 0.95rem;
    }

    .radio-option input[type="radio"]:checked+.radio-label,
    .radio-option .radio-label.active {
      background: linear-gradient(135deg, #ffe000 0%, #ffc700 100%);
      color: #232326;
      border-color: rgba(255, 224, 0, 0.6);
      transform: translateY(-2px);
      box-shadow: 0 8px 18px rgba(255, 224, 0, 0.12);
    }

    .checkbox-group .checkbox-option {
      display: flex;
      gap: 10px;
      align-items: center;
      color: #cfcfcf;
    }

    .message-box {
      padding: 12px;
      margin-bottom: 14px;
      border-radius: 8px;
      font-size: 0.95rem;
      display: none;
      text-align: left;
    }

    .message-box.error {
      background: #3a1f1f;
      color: #ffb4b4;
      border-left: 4px solid #ff8181;
    }

    .message-box.success {
      background: #153126;
      color: #9ff3b0;
      border-left: 4px solid #68d391;
    }

    .primary.full-width {
      width: 100%;
      padding: 12px 18px;
      border-radius: 10px;
      background: linear-gradient(135deg, #ffe000 0%, #ffc700 100%);
      color: #232326;
      font-weight: 700;
      border: none;
      box-shadow: 0 12px 30px rgba(255, 224, 0, 0.12);
    }

    .primary.full-width:hover {
      transform: translateY(-3px);
    }

    .signup-footer {
      margin-top: 14px;
      color: #cfcfcf;
    }

    .signup-footer a.link {
      color: #ffe000;
      font-weight: 600;
    }
  </style>

  <title>Sign Up - LNU AI Society</title>
</head>

<body>
  <Nav />

  <div class="container">
    <div class="hero">
      <h1>Join the LNU AI Society</h1>
      <p>
        Become part of our growing community of AI enthusiasts at Linnaeus
        University. Shape the future with us.
      </p>
    </div>

    <div class="card signup-card">
      <h2>Create Your Account</h2>
      <a href="#" id="googleSignupBtn" class="google-btn">Sign up with Google</a>
      <div class="divider">OR</div>

      <div id="signupMessage" class="message-box"></div>

      <form class="signup-form" id="signupForm">
        <div class="form-row">
          <div class="form-group">
            <label>First Name</label>
            <input type="text" id="firstName" required />
          </div>
          <div class="form-group">
            <label>Last Name</label>
            <input type="text" id="lastName" required />
          </div>
        </div>
        <div class="form-group">
          <label>Email Address</label>
          <input type="email" id="email" required />
          <small>We'll send a verification code to this email.</small>
        </div>
        <div class="form-group">
          <label>Password</label>
          <input type="password" id="password" required />
        </div>
        <div class="form-group">
          <label>Programme</label>
          <input type="text" id="programme" required />
        </div>

        <div class="form-group">
          <label>AI/ML Experience</label>
          <div class="radio-group">
            <label class="radio-option">
              <input type="radio" name="experience" value="beginner" required />
              <span class="radio-label">Beginner</span>
            </label>
            <label class="radio-option">
              <input type="radio" name="experience" value="intermediate" />
              <span class="radio-label">Intermediate</span>
            </label>
            <label class="radio-option">
              <input type="radio" name="experience" value="advanced" />
              <span class="radio-label">Advanced</span>
            </label>
          </div>
        </div>

        <!-- Terms checkbox removed (visual-only request) -->

        <button type="submit" class="primary full-width" id="signupBtn">
          Join The Community
        </button>
      </form>

      <div class="signup-footer">
        <p>
          Already have an account?
          <a href="signin.html" class="link">Sign in here</a>
        </p>
      </div>
    </div>
  </div>

  <Footer />

  <script is:inline>
    // Set Google Signup URL dynamically
    document.getElementById("googleSignupBtn").href = `${CONFIG.getApiBaseUrl()}/oauth2/authorization/google`;

    document
      .getElementById("signupForm")
      .addEventListener("submit", async function (e) {
        e.preventDefault();

        const btn = document.getElementById("signupBtn");
        const msgBox = document.getElementById("signupMessage");
        btn.textContent = "Creating Account...";
        btn.disabled = true;
        msgBox.style.display = "none";

        const firstName = document.getElementById("firstName").value;
        const lastName = document.getElementById("lastName").value;
        const email = document.getElementById("email").value;
        const password = document.getElementById("password").value;
        const programme = document.getElementById("programme").value;
        const experienceInput = document.querySelector(
          'input[name="experience"]:checked',
        ).value;

        let backendLevel = "LOW";
        if (experienceInput === "intermediate") backendLevel = "MID";
        if (experienceInput === "advanced") backendLevel = "HIGH";

        try {
          const response = await fetch(
            `${CONFIG.getApiBaseUrl()}/users/new_member`,
            {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({
                name: firstName + " " + lastName,
                email: email,
                password: password,
                program: programme,
                level: backendLevel,
              }),
            },
          );

          if (response.ok) {
            // SUCCESS: Save email to memory so verify.html knows who it is
            localStorage.setItem("pendingEmail", email);
            msgBox.textContent = "Account created! Sending verification email...";
            msgBox.className = "message-box success";
            msgBox.style.display = "block";
            setTimeout(() => {
              window.location.href = "verify.html";
            }, 1500);
          } else {
            const errorData = await response.json();
            const errorMsg = errorData.message || "Email may already be taken";
            throw new Error(errorMsg);
          }
        } catch (error) {
          msgBox.textContent = error.message;
          msgBox.className = "message-box error";
          msgBox.style.display = "block";
          btn.textContent = "Join The Community";
          btn.disabled = false;
        }
      });
  </script>

  <script is:inline src="scripts/navbar.js"></script>
  <script is:inline src="scripts/hamburger.js"></script>
</body>

</html>
